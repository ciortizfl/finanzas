<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Test de Animación</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, sans-serif; padding: 20px; background: #f0f0f3; }
  h1 { font-size: 18px; margin-bottom: 16px; }
  button {
    display: block; width: 100%; padding: 14px; margin-bottom: 12px;
    border: none; border-radius: 10px; background: #007aff; color: white;
    font-size: 16px; font-weight: 600; cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .box { padding: 20px; margin: 8px 0; background: white; border-radius: 10px; font-size: 15px; }
  #results { margin-top: 20px; padding: 16px; background: #fff; border-radius: 10px; font-size: 13px; white-space: pre-wrap; font-family: monospace; }
  .method-label { font-size: 13px; color: #666; margin: 16px 0 8px; font-weight: 600; }
</style>
</head>
<body>
<h1>Diagnóstico de animaciones (iOS)</h1>

<div id="results">Tocá los botones y observá cuál animación se ve. Reportá cuáles funcionan.</div>

<div class="method-label">MÉTODO 1: Web Animations API</div>
<button onclick="test1()">Probar Método 1</button>
<div id="target1"></div>

<div class="method-label">MÉTODO 2: Clase CSS + animation</div>
<button onclick="test2()">Probar Método 2</button>
<div id="target2"></div>

<div class="method-label">MÉTODO 3: Transición de opacity/transform</div>
<button onclick="test3()">Probar Método 3</button>
<div id="target3"></div>

<div class="method-label">MÉTODO 4: CSS animation con -webkit-</div>
<button onclick="test4()">Probar Método 4</button>
<div id="target4"></div>

<style>
@keyframes fadeInDown2 {
  from { opacity: 0; transform: translateY(-24px); }
  to { opacity: 1; transform: translateY(0); }
}
.anim-css { animation: fadeInDown2 0.7s cubic-bezier(0.22,0.61,0.36,1) both; }

@-webkit-keyframes fadeInDown4 {
  from { opacity: 0; -webkit-transform: translateY(-24px); }
  to { opacity: 1; -webkit-transform: translateY(0); }
}
@keyframes fadeInDown4 {
  from { opacity: 0; transform: translateY(-24px); }
  to { opacity: 1; transform: translateY(0); }
}
.anim-webkit {
  -webkit-animation: fadeInDown4 0.7s cubic-bezier(0.22,0.61,0.36,1) both;
  animation: fadeInDown4 0.7s cubic-bezier(0.22,0.61,0.36,1) both;
}
.trans-box {
  opacity: 0; transform: translateY(-24px);
  transition: opacity 0.7s cubic-bezier(0.22,0.61,0.36,1), transform 0.7s cubic-bezier(0.22,0.61,0.36,1);
}
.trans-box.show { opacity: 1; transform: translateY(0); }
</style>

<script>
function log(msg) {
  document.getElementById('results').textContent = msg;
}

// MÉTODO 1: Web Animations API
function test1() {
  const t = document.getElementById('target1');
  t.innerHTML = '';
  for (let i = 0; i < 3; i++) {
    const box = document.createElement('div');
    box.className = 'box';
    box.textContent = 'Método 1 - Caja ' + (i+1);
    t.appendChild(box);
    try {
      box.animate([
        { opacity: 0, transform: 'translate3d(0,-24px,0)' },
        { opacity: 1, transform: 'translate3d(0,0,0)' }
      ], { duration: 700, delay: i*100, easing: 'cubic-bezier(0.22,0.61,0.36,1)', fill: 'backwards' });
    } catch(e) { log('Método 1 ERROR: ' + e.message); return; }
  }
  log('Método 1 ejecutado. ¿Viste el efecto de bajada?');
}

// MÉTODO 2: Clase CSS
function test2() {
  const t = document.getElementById('target2');
  t.innerHTML = '';
  for (let i = 0; i < 3; i++) {
    const box = document.createElement('div');
    box.className = 'box';
    box.textContent = 'Método 2 - Caja ' + (i+1);
    box.style.animationDelay = (i*0.1) + 's';
    t.appendChild(box);
    void box.offsetWidth;
    box.classList.add('anim-css');
  }
  log('Método 2 ejecutado. ¿Viste el efecto de bajada?');
}

// MÉTODO 3: Transición
function test3() {
  const t = document.getElementById('target3');
  t.innerHTML = '';
  const boxes = [];
  for (let i = 0; i < 3; i++) {
    const box = document.createElement('div');
    box.className = 'box trans-box';
    box.textContent = 'Método 3 - Caja ' + (i+1);
    t.appendChild(box);
    boxes.push(box);
  }
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      boxes.forEach((box, i) => {
        setTimeout(() => box.classList.add('show'), i*100);
      });
    });
  });
  log('Método 3 ejecutado. ¿Viste el efecto de bajada?');
}

// MÉTODO 4: -webkit- animation
function test4() {
  const t = document.getElementById('target4');
  t.innerHTML = '';
  for (let i = 0; i < 3; i++) {
    const box = document.createElement('div');
    box.className = 'box';
    box.textContent = 'Método 4 - Caja ' + (i+1);
    box.style.webkitAnimationDelay = (i*0.1) + 's';
    box.style.animationDelay = (i*0.1) + 's';
    t.appendChild(box);
    void box.offsetWidth;
    box.classList.add('anim-webkit');
  }
  log('Método 4 ejecutado. ¿Viste el efecto de bajada?');
}
</script>
</body>
</html>
